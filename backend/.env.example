# --- Neo4j (graph store) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=setu_dev_password

# --- PostgreSQL + pgvector (vector store) ---
POSTGRES_URL=postgresql://setu:setu_dev_password@localhost:5432/setu

# --- LLM providers (set whichever you're using; auto-detected, no code changes needed) ---
# Precedence if multiple are set: Gemini > Anthropic > OpenAI
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Model selection (locked choices — change here only, nowhere else) ---
# Must match whichever provider's key is set above, e.g.:
#   Gemini:    gemini-2.0-flash  (or gemini-1.5-flash / gemini-1.5-pro)
#   Anthropic: claude-sonnet-4-6
#   OpenAI:    gpt-4o
# Reasoning model used by Copilot / RCA / Compliance / Lessons-Learned agents
LLM_MODEL_REASONING=gemini-2.0-flash
# Cheap/fast model used for structured entity extraction during ingestion
LLM_MODEL_EXTRACTION=gemini-2.0-flash

# --- Embeddings (LOCKED CHOICE — do not change after first ingestion run) ---
# Options: "local" (bge-small-en, 384-dim, no API key) | "google" (uses GEMINI_API_KEY
# above) | "openai" (not implemented yet, 1536-dim)
EMBEDDING_PROVIDER=google
EMBEDDING_DIM=768
# gemini-embedding-001 supports configurable output size (768/1536/3072) via
# output_dimensionality, matched to EMBEDDING_DIM automatically in embedder.py.
# text-embedding-004 (fixed 768-dim) also works if you'd rather not set that param.
EMBEDDING_MODEL_GOOGLE=gemini-embedding-001

# --- App ---
APP_ENV=dev
CORS_ORIGINS=*

# --- Windows-only: uncomment and set these if pdf2image/pytesseract can't
# find poppler/tesseract on PATH (common on Windows). Leave blank on Linux/Mac. ---
# POPPLER_PATH=C:\poppler\Library\bin
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
